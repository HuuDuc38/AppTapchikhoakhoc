<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_white"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Hero image + category tag -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp">

        <ImageView
            android:id="@+id/img_notif_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#2C2C2A" />

        <!-- Category tag overlay -->
        <TextView
            android:id="@+id/tv_notif_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:textSize="10sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:background="@drawable/bg_category_tag_red"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tv_notif_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.4"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Author + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_notif_avatar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:textSize="9sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar_red"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_notif_author"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11.5sp"
                android:textColor="#888888"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_notif_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#BBBBBB" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
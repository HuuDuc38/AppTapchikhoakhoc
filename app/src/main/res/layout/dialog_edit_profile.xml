<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_sheet_bg">

    <!-- ── Handle bar ── -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/sheet_handle"/>

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp">
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_blue"/>
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                android:tint="#3B82F6"
                android:contentDescription=""/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin cá nhân"
                android:textColor="#1A1D23"
                android:textSize="17sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cập nhật hồ sơ của bạn"
                android:textColor="#9CA3AF"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider ngang -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="#F0F1F5"/>

    <!-- ── Form Fields ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="4dp">

        <!-- Họ và tên -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Họ và tên"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_person"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_full_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Nhập họ và tên"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingEnd="14dp"/>
        </LinearLayout>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/email"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Nhập địa chỉ email"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingEnd="14dp"/>
        </LinearLayout>

        <!-- Số điện thoại -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số điện thoại"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_phone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_phone"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_phone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Nhập số điện thoại"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="phone"
                android:maxLines="1"
                android:paddingEnd="14dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Action Buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp">

        <!-- Hủy -->
        <TextView
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Hủy"
            android:textColor="#6B7280"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_cancel_bg"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Lưu -->
        <TextView
            android:id="@+id/btn_dialog_save"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="2"
            android:text="💾  Lưu thay đổi"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_save_red"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>
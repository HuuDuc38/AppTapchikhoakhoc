<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/reaction_popup_bg"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical"
    android:elevation="8dp">

    <TextView
        android:id="@+id/btnReactLike"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="👍"
        android:textSize="26sp"
        android:padding="2dp" />

    <TextView
        android:id="@+id/btnReactLove"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="❤️"
        android:textSize="26sp"
        android:padding="2dp" />

    <TextView
        android:id="@+id/btnReactHaha"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😆"
        android:textSize="26sp"
        android:padding="2dp" />

    <TextView
        android:id="@+id/btnReactWow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😮"
        android:textSize="26sp"
        android:padding="2dp" />

    <TextView
        android:id="@+id/btnReactSad"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😢"
        android:textSize="26sp"
        android:padding="2dp" />

    <TextView
        android:id="@+id/btnReactAngry"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😡"
        android:textSize="26sp"
        android:padding="2dp" />

</LinearLayout>
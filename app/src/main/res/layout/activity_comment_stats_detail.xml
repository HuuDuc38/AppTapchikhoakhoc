<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:background="@drawable/toolbar_gradient_red"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/back"
            android:tint="@android:color/white"
            android:padding="8dp"
            android:background="@drawable/ripple_circle_white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quản lý bình luận"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingEnd="40dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Summary cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalComments"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvLabelTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng bình luận"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <TextView
                            android:id="@+id/tvSummaryTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#111111"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvLabelBinhLuan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="bình luận"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#444444" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViolated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvLabelViolated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vi phạm"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <TextView
                            android:id="@+id/tvSummaryViolated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#B71C1C"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvLabelCanXuLy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="cần xử lý"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#B71C1C" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Tab lọc -->
            <LinearLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@android:color/white"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvFilterAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tất cả"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:paddingTop="12dp"
                        android:paddingBottom="10dp" />

                    <View
                        android:id="@+id/tabIndicatorAll"
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="#C8463D" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvFilterViolated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vi phạm"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#777777"
                        android:paddingTop="12dp"
                        android:paddingBottom="10dp" />

                    <View
                        android:id="@+id/tabIndicatorViolated"
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="#C8463D"
                        android:visibility="invisible" />

                </LinearLayout>

            </LinearLayout>

            <!-- Empty -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có bình luận nào"
                android:gravity="center"
                android:padding="40dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:visibility="gone" />

            <!-- List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
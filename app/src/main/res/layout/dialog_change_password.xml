<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_sheet_bg">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/sheet_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp">
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_orange"/>
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock_outline"
                android:tint="#F5A623"
                android:contentDescription=""/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đổi mật khẩu"
                android:textColor="#1A1D23"
                android:textSize="17sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cập nhật mật khẩu đăng nhập"
                android:textColor="#9CA3AF"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="#F0F1F5"/>

    <!-- Form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="4dp">

        <!-- Mật khẩu hiện tại -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu hiện tại"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_old_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_lock_outline"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_old_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Nhập mật khẩu hiện tại"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="textPassword"
                android:maxLines="1"/>
            <ImageView
                android:id="@+id/toggle_old_password"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_eye"
                android:tint="#C4C9D4"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription=""/>
        </LinearLayout>

        <!-- Mật khẩu mới -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu mới"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_new_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_lock_outline"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_new_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Tối thiểu 6 ký tự"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="textPassword"
                android:maxLines="1"/>
            <ImageView
                android:id="@+id/toggle_new_password"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_eye"
                android:tint="#C4C9D4"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription=""/>
        </LinearLayout>

        <!-- Strength indicator -->
        <TextView
            android:id="@+id/tv_password_strength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone"/>

        <!-- Xác nhận mật khẩu mới -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác nhận mật khẩu mới"
            android:textColor="#374151"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="2dp"/>

        <LinearLayout
            android:id="@+id/row_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_lock_outline"
                android:tint="#C8463D"
                android:layout_marginEnd="10dp"
                android:contentDescription=""/>
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#E9EBF0"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Nhập lại mật khẩu mới"
                android:textSize="14sp"
                android:textColor="#1A1D23"
                android:textColorHint="#BDC3CC"
                android:background="@null"
                android:inputType="textPassword"
                android:maxLines="1"/>
            <ImageView
                android:id="@+id/toggle_confirm_password"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_eye"
                android:tint="#C4C9D4"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription=""/>
        </LinearLayout>

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Hủy"
            android:textColor="#6B7280"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_cancel_bg"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_dialog_save"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="2"
            android:text="Xác nhận"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/btn_save_red"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>
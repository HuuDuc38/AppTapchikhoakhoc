<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/privacy_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:id="@+id/header_privacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="22dp"
        android:background="@drawable/toolbar_gradient_red">

        <!-- Back button với nền mờ -->
        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="10dp">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Quay lại"/>
        </FrameLayout>

        <!-- Shield icon vàng -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="12dp">
            <View
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_header_icon_gold"/>
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield"
                android:tint="#FFFFFF"
                android:contentDescription=""/>
        </FrameLayout>

        <!-- Tiêu đề -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quyền riêng tư"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý tài khoản"
                android:textColor="#BFC5CA"
                android:textSize="12.5sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ SCROLL ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- ── SECTION: TÀI KHOẢN ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÀI KHOẢN"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_rounded"
                android:elevation="3dp"
                android:layout_marginBottom="8dp">

                <!-- Thông tin cá nhân -->
                <LinearLayout
                    android:id="@+id/btn_personal_info"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="14dp">
                        <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_blue"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_person" android:tint="#3B82F6" android:contentDescription=""/>
                    </FrameLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thông tin cá nhân" android:textColor="#1A1D23" android:textSize="14.5sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tv_personal_info_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên, email, số điện thoại" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    </LinearLayout>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:tint="#D1D5DB" android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="70dp" android:background="#F0F1F5"/>

                <!-- Đổi mật khẩu -->
                <LinearLayout
                    android:id="@+id/btn_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="14dp">
                        <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_orange"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_lock_outline" android:tint="#F5A623" android:contentDescription=""/>
                    </FrameLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đổi mật khẩu" android:textColor="#1A1D23" android:textSize="14.5sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cập nhật mật khẩu đăng nhập" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    </LinearLayout>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:tint="#D1D5DB" android:contentDescription=""/>
                </LinearLayout>

            </LinearLayout>

            <!-- ── SECTION: BẢO MẬT ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BẢO MẬT"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_rounded"
                android:elevation="3dp">

                <!-- Xác thực 2 bước -->
                <LinearLayout
                    android:id="@+id/btn_two_factor"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="14dp">
                        <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_green"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_shield" android:tint="#10B981" android:contentDescription=""/>
                    </FrameLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Xác thực 2 bước" android:textColor="#1A1D23" android:textSize="14.5sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tăng cường bảo mật tài khoản" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mới"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/badge_new_red"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:tint="#D1D5DB" android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="70dp" android:background="#F0F1F5"/>

                <!-- Phiên đăng nhập -->
                <LinearLayout
                    android:id="@+id/btn_active_sessions"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="14dp">
                        <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_red"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_devices" android:tint="#EF4444" android:contentDescription=""/>
                    </FrameLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phiên đăng nhập" android:textColor="#1A1D23" android:textSize="14.5sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tv_session_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1 thiết bị đang hoạt động" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    </LinearLayout>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:tint="#D1D5DB" android:contentDescription=""/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
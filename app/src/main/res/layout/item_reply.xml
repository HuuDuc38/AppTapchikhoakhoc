<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/tvReplyAvatar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/avatar_circle_bg"
        android:gravity="center"
        android:text="B"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="7dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/replyBubbleLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/comment_bubble_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvReplyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/comment_default_name"
                android:textColor="#1C1E21"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReplyContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/comment_default_content"
                android:textColor="#1C1E21"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvReplyTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"
            android:text="Vừa xong"
            android:textColor="#65676B"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_white"
    android:gravity="top"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/img_featured_thumb"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:scaleType="centerCrop"
        android:background="#EEEEEE" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- Category -->
        <TextView
            android:id="@+id/tv_featured_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#C0392B"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_marginBottom="5dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_featured_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.35"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Author + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_featured_avatar"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:textSize="7sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar_red"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tv_featured_author"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="#999999"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_featured_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10.5sp"
                android:textColor="#BBBBBB" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!-- item_admin_article.xml — Full-width, no rounded corners, balanced design -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAdminArticle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:background="#1E2A38"
    android:elevation="2dp">

    <!-- ── Ảnh thumbnail full width ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <ImageView
            android:id="@+id/imgThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Ảnh bài viết" />

        <!-- Gradient overlay từ dưới lên -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_bottom_overlay" />

        <!-- Badge DANH MỤC — góc trên trái -->
        <TextView
            android:id="@+id/tvAdminCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_category_green"
            android:text="Danh mục"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Badge TRẠNG THÁI — góc trên phải -->
        <TextView
            android:id="@+id/tvAdminStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:background="@drawable/badge_approved_bg"
            android:text="✅ Đã duyệt"
            android:textColor="#00D9A5"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Tiêu đề nằm dưới ảnh, chồng lên gradient -->
        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:paddingTop="48dp"
            android:ellipsize="end"
            android:lineSpacingExtra="3dp"
            android:maxLines="2"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:text="Tiêu đề bài viết"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- ── Khu vực nội dung bên dưới ảnh ── -->
    <LinearLayout
        android:id="@+id/layoutAdminCardBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E2A38"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Tóm tắt nội dung -->
        <TextView
            android:id="@+id/tvAdminContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="3dp"
            android:maxLines="2"
            android:text="Tóm tắt nội dung bài viết hiển thị ở đây..."
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <!-- Divider -->
        <View
            android:id="@+id/dividerAdmin"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="12dp"/>

        <!-- Hàng tác giả + nút edit/delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar chữ cái -->
            <TextView
                android:id="@+id/tvAdminAvatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Tên tác giả + thời gian -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAdminAuthorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Nguyễn Văn A"
                    android:textColor="#EEEEEE"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/08/2026 22:48"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Nút Edit -->
            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_edit"
                android:contentDescription="Chỉnh sửa"
                app:tint="#9E9E9E" />

            <!-- Nút Xóa -->
            <ImageView
                android:id="@+id/btnDeleteAdmin"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_delete_24"
                android:contentDescription="Xóa bài viết"
                app:tint="#E53935" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
    <!-- ══ FAQ Admin ══ -->
    <string name="faq_q1">❓  How to add an article?</string>
    <string name="faq_a1">Go to \'Article Management\' → tap \'+\' in the bottom right → fill in the details and tap \'Publish\'.</string>
    <string name="faq_q2">❓  What are pending articles?</string>
    <string name="faq_a2">Articles submitted by users that need Admin review. Go to \'Pending Articles\' to approve or reject them.</string>
    <string name="faq_q3">❓  How to delete an article?</string>
    <string name="faq_a3">Go to the article list → long press the article → select \'Delete\'. Note: this action cannot be undone.</string>
    <string name="faq_q4">❓  Forgot admin password?</string>
    <string name="faq_a4">Contact the system administrator or email: admin@tapchikhoakhoc.edu.vn to reset your password.</string>
    <string name="faq_q5">❓  App is not working?</string>
    <string name="faq_a5">Try closing and reopening the app. If the issue persists, contact technical support via the email below.</string>

